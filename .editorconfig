[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.css]
indent_size = 2
indent_style = tab

[.gitignore]
insert_final_newline = true

[*.html]
indent_size = 2
indent_style = tab
insert_final_newline = true

[*.ini]
insert_final_newline = true

[*.js]
indent_size = 2
indent_style = space
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.php]
indent_size = 4
indent_style = space
insert_final_newline = true

[*.tpl]
insert_final_newline = true

[*.twig]
insert_final_newline = true